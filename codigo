# 2. SISTEMA DE GESTÃO E PERSISTÊNCIA
# =====================================================================

class ClinicaController:
    ARQUIVO_DADOS = "dados_clinica.txt"

    def __init__(self):
        self.especialidades: List[Especialidade] = []
        self.procedimentos: List[Procedimento] = []
        self.pacientes: List[Paciente] = []
        self.profissionais: List[Profissional] = []
        self.consultas: List[Consulta] = []

    def salvar_dados(self):
        """Escreve o estado atual de todas as listas no arquivo txt."""
        try:
            with open(self.ARQUIVO_DADOS, "w", encoding="utf-8") as f:
                # 1. Especialidades
                f.write(f"[ESPECIALIDADES]\n")
                for e in self.especialidades:
                    f.write(f"{e.nome};{e.valor_particular};{e.valor_convenio}\n")
                
                # 2. Procedimentos
                f.write(f"[PROCEDIMENTOS]\n")
                for p in self.procedimentos:
                    f.write(f"{p.nome};{p.valor_particular};{p.valor_convenio}\n")

                # 3. Pacientes
                f.write(f"[PACIENTES]\n")
                for pac in self.pacientes:
                    conv = pac.convenio_nome if pac.convenio_nome else "None"
                    f.write(f"{pac.nome};{pac.cpf};{pac.tipo_atendimento.value};{conv};{pac.faltas}\n")

                # 4. Profissionais e Horários
                f.write(f"[PROFISSIONAIS]\n")
                for prof in self.profissionais:
                    # Salva dados básicos e os slots de agenda correspondentes
                    agenda_str = ",".join([f"{s.data_hora.isoformat()}|{s.status.value}" for s in prof.agenda])
                    f.write(f"{prof.nome};{prof.registro};{prof.especialidade.nome};{prof.status.value};{agenda_str}\n")

                # 5. Consultas
                f.write(f"[CONSULTAS]\n")
                for c in self.consultas:
                    proc_nomes = ",".join([p.nome for p in c.procedimentos_extras])
                    f.write(f"{c.paciente.cpf};{c.profissional.registro};{c.slot.data_hora.isoformat()};{c.tipo_visita.value};{c.status};{c.diagnostico};{proc_nomes}\n")

        except IOError as e:
            print(f"\n Erro crítico ao salvar os dados no disco: {e}")

    def carregar_dados(self):
        """Lê o arquivo txt e reconstrói as instâncias de objetos em memória."""
        if not os.path.exists(self.ARQUIVO_DADOS):
            # Cria dados iniciais básicos se o arquivo não existir
            self._criar_dados_iniciais()
            return

        try:
            with open(self.ARQUIVO_DADOS, "r", encoding="utf-8") as f:
                secao_atual = None
                for linha in f:
                    linha = linha.strip()
                    if not linha:
                        continue
                    if linha.startswith("[") and linha.endswith("]"):
                        secao_atual = linha
                        continue

                    partes = linha.split(";")
                    
                    if secao_atual == "[ESPECIALIDADES]":
                        self.especialidades.append(Especialidade(partes[0], float(partes[1]), float(partes[2])))
                    
                    elif secao_atual == "[PROCEDIMENTOS]":
                        self.procedimentos.append(Procedimento(partes[0], float(partes[1]), float(partes[2])))

                    elif secao_atual == "[PACIENTES]":
                        tipo = TipoAtendimento.PARTICULAR if partes[2] == "Particular" else TipoAtendimento.CONVENIO
                        conv = None if partes[3] == "None" else partes[3]
                        pac = Paciente(partes[0], partes[1], tipo, conv)
                        pac.faltas = int(partes[4])
                        self.pacientes.append(pac)

                    elif secao_atual == "[PROFISSIONAIS]":
                        esp = next((e for e in self.especialidades if e.nome == partes[2]), None)
                        if esp:
                            prof = Profissional(partes[0], partes[1], esp)
                            prof.status = StatusProfissional.ATIVO if partes[3] == "Ativo" else StatusProfissional.AFASTADO
                            
                            # Reconstrói os slots da agenda
                            if partes[4]:
                                slots_raw = partes[4].split(",")
                                for s_raw in slots_raw:
                                    dt_iso, status_val = s_raw.split("|")
                                    slot = AgendaSlot(datetime.fromisoformat(dt_iso))
                                    slot.status = StatusSlot.AGENDADO if status_val == "Agendado" else StatusSlot.DISPONIVEL
                                    prof.agenda.append(slot)
                            self.profissionais.append(prof)

                    elif secao_atual == "[CONSULTAS]":
                        pac = next((p for p in self.pacientes if p.cpf == partes[0]), None)
                        prof = next((pr for pr in self.profissionais if pr.registro == partes[1]), None)
                        dt_consulta = datetime.fromisoformat(partes[2])
                        
                        if pac and prof:
                            slot = next((s for s in prof.agenda if s.data_hora == dt_consulta), None)
                            if not slot:
                                # Se o slot não existir por inconsistência, recria ele
                                slot = AgendaSlot(dt_consulta)
                                prof.agenda.append(slot)
                            
                            tipo_v = TipoVisita.PRIMEIRA if partes[3] == "Primeira Consulta" else TipoVisita.RETORNO
                            
                            # Para carregar sem lançar a exceção de slot ocupado do construtor
                            slot.status = StatusSlot.DISPONIVEL 
                            c = Consulta(pac, prof, slot, tipo_v)
                            c.status = partes[4]
                            c.diagnostico = partes[5]
                            
                            if partes[6]:
                                nomes_proc = partes[6].split(",")
                                for np in nomes_proc:
                                    proc_obj = next((p for p in self.procedimentos if p.nome == np), None)
                                    if proc_obj:
                                        c.procedimentos_extras.append(proc_obj)
                            self.consultas.append(c)
        except Exception as e:
            print(f"\n Aviso: O arquivo de dados está corrompido ou inacessível. Iniciando com dados padrão. Detalhe: {e}")
            self._criar_dados_iniciais()

    def _criar_dados_iniciais(self):
        """Cria especialidades e procedimentos padrão se for a primeira execução do sistema."""
        self.especialidades = [
            Especialidade("Clínica Médica", 150.0, 70.0),
            Especialidade("Odontologia Geral", 180.0, 90.0),
            Especialidade("Pediatria", 200.0, 100.0)
        ]
        self.procedimentos = [
            Procedimento("Limpeza Preventiva", 120.0, 50.0),
            Procedimento("Aplicação de Flúor", 60.0, 30.0),
            Procedimento("Raio-X de Controle", 90.0, 40.0)
        ]
        self.salvar_dados()

