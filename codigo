import os
import sys
from datetime import datetime
from enum import Enum
from typing import List, Optional

# =====================================================================
# 1. ENUMS E CLASSES DE DOMÍNIO
# =====================================================================

class TipoAtendimento(Enum):
    PARTICULAR = "Particular"
    CONVENIO = "Convênio"

class StatusProfissional(Enum):
    ATIVO = "Ativo"
    AFASTADO = "Afastado"

class StatusSlot(Enum):
    DISPONIVEL = "Disponível"
    AGENDADO = "Agendado"

class TipoVisita(Enum):
    PRIMEIRA = "Primeira Consulta"
    RETORNO = "Retorno"

class Especialidade:
    def __init__(self, nome: str, valor_particular: float, valor_convenio: float):
        self.nome = nome
        self.valor_particular = valor_particular
        self.valor_convenio = valor_convenio

    def __str__(self):
        return f"{self.nome} (Part: R${self.valor_particular:.2f} | Conv: R${self.valor_convenio:.2f})"

class Procedimento:
    def __init__(self, nome: str, valor_particular: float, valor_convenio: float):
        self.nome = nome
        self.valor_particular = valor_particular
        self.valor_convenio = valor_convenio

    def __str__(self):
        return f"{self.nome} (Part: R${self.valor_particular:.2f} | Conv: R${self.valor_convenio:.2f})"

class Paciente:
    def __init__(self, nome: str, cpf: str, tipo_atendimento: TipoAtendimento, convenio_nome: Optional[str] = None):
        self.nome = nome
        self.cpf = cpf
        self.tipo_atendimento = tipo_atendimento
        self.convenio_nome = convenio_nome
        self.faltas = 0

    def __str__(self):
        info_conv = f" ({self.convenio_nome})" if self.tipo_atendimento == TipoAtendimento.CONVENIO else ""
        return f"{self.nome} (CPF: {self.cpf}) - {self.tipo_atendimento.value}{info_conv}"

class AgendaSlot:
    def __init__(self, data_hora: datetime):
        self.data_hora = data_hora
        self.status = StatusSlot.DISPONIVEL

class Profissional:
    def __init__(self, nome: str, registro: str, especialidade: Especialidade):
        self.nome = nome
        self.registro = registro  # CRM ou CRO
        self.especialidade = especialidade
        self.status = StatusProfissional.ATIVO
        self.agenda: List[AgendaSlot] = []

    def __str__(self):
        return f"{self.nome} ({self.registro}) - {self.especialidade.nome} [{self.status.value}]"

class Consulta:
    def __init__(self, paciente: Paciente, profissional: Profissional, slot: AgendaSlot, tipo_visita: TipoVisita):
        # Validação de segurança: Profissional deve estar ativo para novas consultas
        if profissional.status != StatusProfissional.ATIVO:
            raise ValueError(f"O profissional {profissional.nome} não está com a agenda ativa.")
        
        # Validação de segurança: Impedir conflito de horário
        if slot.status != StatusSlot.DISPONIVEL:
            raise ValueError("Conflito de Horário! Este slot de tempo já está ocupado.")

        self.paciente = paciente
        self.profissional = profissional
        self.slot = slot
        self.tipo_visita = tipo_visita
        self.status = "Agendada"
        self.procedimentos_extras: List[Procedimento] = []
        self.diagnostico: str = ""
        
        # Ocupa o slot de tempo imediatamente
        self.slot.status = StatusSlot.AGENDADO

    def calcular_total(self) -> float:
        """Calcula dinamicamente o valor da consulta somado aos procedimentos extras."""
        # Se for retorno dentro do prazo de acompanhamento, o valor base da consulta é zero
        if self.tipo_visita == TipoVisita.RETORNO:
            valor_base = 0.0
        else:
            if self.paciente.tipo_atendimento == TipoAtendimento.PARTICULAR:
                valor_base = self.profissional.especialidade.valor_particular
            else:
                valor_base = self.profissional.especialidade.valor_convenio

        # Soma os procedimentos adicionais efetuados
        total_procedimentos = 0.0
        for proc in self.procedimentos_extras:
            if self.paciente.tipo_atendimento == TipoAtendimento.PARTICULAR:
                total_procedimentos += proc.valor_particular
            else:
                total_procedimentos += proc.valor_convenio

        return valor_base + total_procedimentos

