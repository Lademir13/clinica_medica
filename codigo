class InterfaceTerminal:
    def __init__(self):
        self.controller = ClinicaController()
        self.controller.carregar_dados()

    def limpar_tela(self):
        os.system('cls' if os.name == 'nt' else 'clear')

    def exibir_cabecalho(self, titulo: str):
        print("=" * 60)
        print(f"{titulo.center(60)}")
        print("=" * 60)

    def aguardar_input(self):
        input("\nPressione [ENTER] para retornar ao menu...")

    def menu_principal(self):
        while True:
            self.limpar_tela()
            self.exibir_cabecalho("🏥 SISTEMA INTEGRADO DE CLÍNICA MÉDICA/ODONTO")
            print(" 1. Cadastrar Novo Paciente")
            print(" 2. Cadastrar Novo Profissional de Saúde")
            print(" 3. Disponibilizar Horário na Agenda de um Profissional")
            print(" 4. Agendar Nova Consulta")
            print(" 5. Realizar/Concluir Consulta (Prontuário)")
            print(" 6. Registrar Falta ou Cancelamento")
            print(" 7. Listar Cadastros Gerais da Clínica")
            print(" 0. Salvar e Sair")
            print("=" * 60)
            
            opcao = input("Selecione a operação desejada: ").strip()
            
            if opcao == "1":
                self.cadastrar_paciente()
            elif opcao == "2":
                self.cadastrar_profissional()
            elif opcao == "3":
                self.gerar_agenda()
            elif opcao == "4":
                self.agendar_consulta()
            elif opcao == "5":
                self.concluir_consulta_interface()
            elif opcao == "6":
                self.registrar_falta_cancelamento()
            elif opcao == "7":
                self.listar_tudo()
            elif opcao == "0":
                self.controller.salvar_dados()
                print("\n Dados salvos com sucesso! Encerrando sistema...")
                sys.exit(0)
            else:
                print("\n Opção inválida! Tente novamente.")
                self.aguardar_input()

    def cadastrar_paciente(self):
        self.limpar_tela()
        self.exibir_cabecalho("CADASTRO DE PACIENTE")
        try:
            nome = input("Nome Completo: ").strip()
            if not nome: raise ValueError("O nome não pode estar em branco.")
            
            cpf = input("CPF (apenas números): ").strip()
            if not cpf: raise ValueError("CPF é obrigatório.")
            if any(p.cpf == cpf for p in self.controller.pacientes):
                raise ValueError("Este CPF já está cadastrado no sistema.")

            print("\nTipo de Atendimento:")
            print("1. Particular")
            print("2. Convênio")
            tipo_op = input("Opção: ").strip()

            if tipo_op == "1":
                tipo = TipoAtendimento.PARTICULAR
                convenio = None
            elif tipo_op == "2":
                tipo = TipoAtendimento.CONVENIO
                convenio = input("Nome da Operadora do Convênio: ").strip()
                if not convenio: raise ValueError("Nome do convênio não pode ser em branco.")
            else:
                raise ValueError("Opção de atendimento inválida.")

            novo_paciente = Paciente(nome, cpf, tipo, convenio)
            self.controller.pacientes.append(novo_paciente)
            self.controller.salvar_dados()
            print(f"\n Paciente {nome} cadastrado com sucesso!")

        except ValueError as e:
            print(f"\n Erro no cadastro: {e}")
        self.aguardar_input()

    def cadastrar_profissional(self):
        self.limpar_tela()
        self.exibir_cabecalho("CADASTRO DE PROFISSIONAL DE SAÚDE")
        try:
            nome = input("Nome do Profissional: ").strip()
            if not nome: raise ValueError("O nome é obrigatório.")

            registro = input("Registro de Classe (CRM/CRO): ").strip().upper()
            if not registro: raise ValueError("O registro profissional é obrigatório.")
            if any(p.registro == registro for p in self.controller.profissionais):
                raise ValueError("Este registro de classe já está cadastrado.")

            print("\nSelecione a Especialidade:")
            for idx, esp in enumerate(self.controller.especialidades, 1):
                print(f"{idx}. {esp}")
            
            esp_op = int(input("Escolha o número: ").strip()) - 1
            if esp_op < 0 or esp_op >= len(self.controller.especialidades):
                raise ValueError("Especialidade selecionada inválida.")
            
            especialidade_escolhida = self.controller.especialidades[esp_op]
            
            novo_prof = Profissional(nome, registro, especialidade_escolhida)
            self.controller.profissionais.append(novo_prof)
            self.controller.salvar_dados()
            print(f"\n Dr(a). {nome} cadastrado com sucesso!")

        except (ValueError, IndexError):
            print("\n Entrada de dados inválida ou fora dos limites permitidos.")
        self.aguardar_input()

    def gerar_agenda(self):
        self.limpar_tela()
        self.exibir_cabecalho("DISPONIBILIZAR AGENDA")
        try:
            if not self.controller.profissionais:
                print("Nenhum profissional cadastrado no sistema.")
                self.aguardar_input()
                return

            print("Selecione o Profissional:")
            for idx, p in enumerate(self.controller.profissionais, 1):
                print(f"{idx}. {p}")
            
            prof_op = int(input("Escolha o número: ").strip()) - 1
            prof = self.controller.profissionais[prof_op]

            data_str = input("Digite a data da agenda (DD/MM/AAAA): ").strip()
            hora_str = input("Digite o horário de início (HH:MM): ").strip()
            
            data_hora = datetime.strptime(f"{data_str} {hora_str}", "%d/%m/%Y %H:%M")
            
            # Evita duplicar exatamente o mesmo horário de agenda para o mesmo profissional
            if any(slot.data_hora == data_hora for slot in prof.agenda):
                raise ValueError("Este horário já existe na agenda deste profissional.")

            prof.adicionar_horario(data_hora)
            self.controller.salvar_dados()
            print(f"\n Horário {data_hora.strftime('%d/%m/%Y %H:%M')} adicionado para Dr(a). {prof.nome}")

        except Exception as e:
            print(f"\n Erro ao adicionar horário: {e}")
        self.aguardar_input()

    def agendar_consulta(self):
        self.limpar_tela()
        self.exibir_cabecalho("MARCAÇÃO DE CONSULTA")
        try:
            if not self.controller.pacientes or not self.controller.profissionais:
                raise ValueError("É necessário ter pelo menos um paciente e um profissional cadastrados.")

            # 1. Seleciona Paciente
            print("Escolha o Paciente:")
            for idx, pac in enumerate(self.controller.pacientes, 1):
                print(f"{idx}. {pac}")
            pac_op = int(input("Escolha o número: ").strip()) - 1
            paciente = self.controller.pacientes[pac_op]

            # 2. Seleciona Profissional
            print("\nEscolha o Profissional:")
            for idx, prof in enumerate(self.controller.profissionais, 1):
                print(f"{idx}. {prof}")
            prof_op = int(input("Escolha o número: ").strip()) - 1
            profissional = self.controller.profissionais[prof_op]

            # 3. Escolhe Horário Disponível
            slots_livres = [s for s in profissional.agenda if s.status == StatusSlot.DISPONIVEL]
            if not slots_livres:
                raise ValueError(f"Não há horários disponíveis para o profissional {profissional.nome}.")

            print("\nHorários livres na agenda:")
            for idx, slot in enumerate(slots_livres, 1):
                print(f"{idx}. {slot.data_hora.strftime('%d/%m/%Y às %H:%M')}")
            slot_op = int(input("Selecione o horário desejado: ").strip()) - 1
            slot_escolhido = slots_livres[slot_op]

     